# ─── Database (Supabase) ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Optional: Supabase Storage for images ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ─── API seed only (prisma/seed-via-api.mjs, prisma/seed-api.sh) ─────
# Create a PAT at https://supabase.com/dashboard/account/tokens — never commit it.
SUPABASE_ACCESS_TOKEN=""
# Project → Settings → General → Reference ID
SUPABASE_PROJECT_REF=""

# ─── Rate Limiting (optional — Upstash Redis) ─────────────────────────
# Without these, rate limiting is silently disabled (no errors).
# Create a free Redis DB at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
